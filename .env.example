# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Authentication ---
# Credentials for the insurance/admin account.
ADMIN_USERNAME=admin_insurance
# REQUIRED: set a strong password. If left empty, admin login is disabled.
ADMIN_PASSWORD=

# REQUIRED for provider logins: shared password providers must supply.
# If left empty, all provider logins are rejected.
PROVIDER_PASSWORD=

# --- Runtime ---
# Set to "true" only for local development (enables auto-reload).
DEBUG=false
# Bind address for `python -m app.main`. Use 0.0.0.0 only behind a proxy/firewall.
HOST=127.0.0.1
PORT=8000

# Comma-separated extra CORS origins to allow (optional).
ALLOWED_ORIGINS=

# --- Database (only needed for the Azure SQL scripts) ---
DB_SERVER=
DB_NAME=
DB_UID=
DB_PWD=
